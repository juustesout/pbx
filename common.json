{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.json",
  "title": "Common definitions for Project Brief Schema",
  "description": "Reusable definitions and field wrapper used across the Project Brief modular schema.",
  "$defs": {
    "uuid": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$",
      "examples": ["3fa85f64-5717-4562-b3fc-2c963f66afa6"],
      "title": "UUID",
      "description": "UUID v1-v5 compatible identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "examples": ["2026-07-14T12:00:00Z"],
      "title": "Timestamp",
      "description": "ISO 8601 timestamp"
    },
    "weight": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.5,
      "examples": [0.0, 0.25, 0.75, 1.0],
      "description": "Normalized weight between 0 (lowest) and 1 (highest)"
    },
    "aiMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1, "description": "Model confidence as normalized score" },
        "completionScore": { "type": "number", "minimum": 0, "maximum": 1, "description": "How complete the AI believes the field is" },
        "sourceAttribution": { "type": "array", "items": { "type": "string" }, "description": "List of source identifiers or URIs used by the AI" },
        "reasoning": { "type": "string", "description": "Short explanation of AI reasoning for this field" },
        "citations": { "type": "array", "items": { "type": "object", "properties": { "label": {"type":"string"}, "uri": {"type":"string","format":"uri"}, "excerpt": {"type":"string"} }, "required": ["label","uri"] } },
        "humanVerified": { "type": "boolean", "default": false },
        "aiGenerated": { "type": "boolean", "default": false },
        "needsReview": { "type": "boolean", "default": false },
        "conflicts": { "type": "array", "items": { "type": "string" }, "description": "Identifiers of conflicting fields or notes" },
        "missingDependencies": { "type": "array", "items": { "type": "string" }, "description": "IDs of fields this item depends on but are missing" },
        "qualityScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "semanticEmbeddingId": { "type": "string" },
        "vectorNamespace": { "type": "string" }
      },
      "description": "AI provenance and evaluation metadata"
    },
    "fieldMeta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/ $defs/uuid" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "required": { "type": "boolean", "default": false },
        "example": {},
        "examples": { "type": "array", "items": {} },
        "default": {},
        "validationRules": { "type": "object", "description": "Free-form validation rules map (human readable)" },
        "enum": { "type": "array", "items": {} },
        "minimum": { "type": ["number","null"] },
        "maximum": { "type": ["number","null"] },
        "pattern": { "type": "string" },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "relatedFields": { "type": "array", "items": { "type": "string" } },
        "importanceWeight": { "$ref": "#/ $defs/weight" },
        "completionWeight": { "$ref": "#/ $defs/weight" },
        "aiPrompt": { "type": "string" },
        "followUpQuestions": { "type": "array", "items": { "type": "string" } },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "editable": { "type": "boolean", "default": true },
        "generated": { "type": "boolean", "default": false },
        "generatedBy": { "type": "string" },
        "reviewStatus": { "type": "string", "enum": ["draft","review","approved","rejected","needs-info"], "default": "draft" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "source": { "type": "string" },
        "lastUpdated": { "$ref": "#/ $defs/timestamp" },
        "version": { "type": "string" },
        "aiMetadata": { "$ref": "#/ $defs/aiMetadata" }
      },
      "required": ["id","title","type","lastUpdated","version"],
      "description": "Structured metadata required for every field"
    },
    "fieldWrapper": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "meta": { "$ref": "#/ $defs/fieldMeta" },
        "value": {}
      },
      "required": ["meta","value"],
      "description": "Generic wrapper: every logical field is an object with `meta` and `value`. `meta` contains administrative and AI metadata; `value` contains the typed content."
    },
    "personRef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/ $defs/uuid" },
        "name": { "type": "string" },
        "role": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "required": ["id","name"],
      "description": "Lightweight person reference used in stakeholders and users"
    },
    "reference": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/ $defs/uuid" },
        "label": { "type": "string" },
        "uri": { "type": "string", "format": "uri" }
      },
      "required": ["id","label"],
      "additionalProperties": false
    },
    "requirementRef": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/ $defs/uuid" },
        "title": { "type": "string" }
      },
      "required": ["id"],
      "additionalProperties": false
    },
    "riskRef": {
      "type": "object",
      "properties": {
        "id": { "$ref": "#/ $defs/uuid" },
        "title": { "type": "string" }
      },
      "required": ["id"],
      "additionalProperties": false
    }
  }
}
