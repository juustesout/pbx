{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "assumptions.json",
  "title": "Assumptions",
  "description": "Assumptions made during idea capture and analysis.",
  "type": "object",
  "properties": {
    "assumptions": { "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "type": "object", "properties": { "id": { "$ref": "common.json#/$defs/uuid" }, "statement": { "type": "string" }, "rationale": { "type": "string" }, "confidence": { "type": "number","minimum":0,"maximum":1 } }, "required": ["id","statement"] } } } } ] }
  },
  "required": ["assumptions"],
  "additionalProperties": false
}
