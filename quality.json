{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quality.json",
  "title": "Quality",
  "description": "Quality attributes, acceptance gates and QA measures.",
  "type": "object",
  "properties": {
    "qualityGates": { "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "type": "object", "properties": { "id": { "$ref": "common.json#/$defs/uuid" }, "name": { "type": "string" }, "criteria": { "type": "array", "items": { "type": "string" } } }, "required": ["id","name"] } } } } ] }
  },
  "required": ["qualityGates"],
  "additionalProperties": false
}
