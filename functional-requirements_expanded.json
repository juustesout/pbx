                  },
                  "title": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "priority": {
                    "type": "string",
                    "enum": [
                      "low",
                      "medium",
                      "high",
                      "must"
                    ]
                  },
                  "acceptanceCriteria": {
                    "type": "array",
                    "items": {
                      "$ref": "acceptance.json"
                    }
                  },
                  "dependsOn": {
                    "type": "array",
                    "items": {
                      "$ref": "common_expanded.json#/$defs/requirementRef"
                    }
                  },
                  "relatedProcesses": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "id",
                  "title"
                ]
              }
            }
          },
          "required": [
            "meta",
            "value"
          ]
