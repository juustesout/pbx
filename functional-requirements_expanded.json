{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "functional-requirements.json",
  "title": "Functional Requirements",
  "description": "Canonical functional requirements register with traceability.",
  "type": "object",
  "properties": {
    "requirements": {
      "allOf": [
        {
          "$ref": "common_expanded.json#/$defs/fieldWrapper"
        },
        {
          "properties": {
            "meta": {
              "$ref": "common_expanded.json#/$defs/fieldMeta"
            },
            "value": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
