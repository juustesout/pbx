{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "non-functional-requirements.json",
  "title": "Non-Functional Requirements",
  "description": "Performance, security, reliability and other NFRs.",
  "type": "object",
  "properties": {
    "nonFunctionalRequirements": { "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "type": "object", "properties": { "id": { "$ref": "common.json#/$defs/uuid" }, "category": { "type": "string" }, "description": { "type": "string" }, "metric": { "$ref": "success-metrics.json" }, "target": {} }, "required": ["id","category"] } } } } ] }
  },
  "required": ["nonFunctionalRequirements"],
  "additionalProperties": false
}
