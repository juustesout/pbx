{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "references.json",
  "title": "References",
  "description": "External documents and reference material.",
  "type": "object",
  "properties": {
    "references": { "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "$ref": "common.json#/$defs/reference" } } } } ] }
  },
  "required": ["references"],
  "additionalProperties": false
}
