{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "project-brief-schema.json",
  "title": "Project Brief Schema (AI-native, PRINCE2-inspired)",
  "description": "Root schema that composes all modular project brief components.",
  "type": "object",
  "properties": {
    "metadata": { "$ref": "metadata.json" },
    "projectDefinition": { "$ref": "project-definition.json" },
    "businessCase": { "$ref": "business-case.json" },
    "stakeholders": { "$ref": "stakeholders.json" },
    "users": { "$ref": "users.json" },
    "personas": { "$ref": "personas.json" },
    "businessProcesses": { "$ref": "business-processes.json" },
    "problemDomain": { "$ref": "problem-domain.json" },
    "opportunities": { "$ref": "opportunities.json" },
    "constraints": { "$ref": "constraints.json" },
    "assumptions": { "$ref": "assumptions.json" },
    "dependencies": { "$ref": "dependencies.json" },
    "risks": { "$ref": "risks.json" },
    "scope": { "$ref": "scope.json" },
    "outcomes": { "$ref": "outcomes.json" },
    "successMetrics": { "$ref": "success-metrics.json" },
    "productDescription": { "$ref": "product-description.json" },
    "functionalRequirements": { "$ref": "functional-requirements.json" },
    "nonFunctionalRequirements": { "$ref": "non-functional-requirements.json" },
    "quality": { "$ref": "quality.json" },
    "solutionOptions": { "$ref": "solution-options.json" },
    "technologyConsiderations": { "$ref": "technology-considerations.json" },
    "interfaces": { "$ref": "interfaces.json" },
    "acceptance": { "$ref": "acceptance.json" },
    "governance": { "$ref": "governance.json" },
    "references": { "$ref": "references.json" },
    "glossary": { "$ref": "glossary.json" },
    "decisions": { "$ref": "decisions.json" },
    "openQuestions": { "$ref": "open-questions.json" },
    "aiMetadata": { "$ref": "ai-metadata.json" }
  },
  "required": ["metadata","projectDefinition"],
  "additionalProperties": false
}
