{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "glossary.json",
  "title": "Glossary",
  "description": "Glossary of domain and project terms.",
  "type": "object",
  "properties": {
    "terms": { "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "type": "object", "properties": { "term": { "type": "string" }, "definition": { "type": "string" }, "source": { "$ref": "common.json#/$defs/reference" } }, "required": ["term","definition"] } } } } ] }
  },
  "required": ["terms"],
  "additionalProperties": false
}
