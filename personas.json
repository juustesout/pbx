{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "personas.json",
  "title": "Personas",
  "description": "Detailed user personas for empathy and acceptance criteria generation.",
  "type": "object",
  "properties": {
    "personas": {
      "allOf": [ { "$ref": "common.json#/$defs/fieldWrapper" }, { "properties": { "meta": { "required": ["id","title","type","lastUpdated","version"] }, "value": { "type": "array", "items": { "type": "object", "properties": { "id": { "$ref": "common.json#/$defs/uuid" }, "name": { "type": "string" }, "summary": { "type": "string" }, "goals": { "type": "array", "items": { "type": "string" } }, "painPoints": { "type": "array", "items": { "type": "string" } }, "scenarios": { "type": "array", "items": { "type": "string" } } }, "required": ["id","name"] } } } } ]
    }
  },
  "required": ["personas"],
  "additionalProperties": false
}
